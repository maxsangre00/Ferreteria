    nombre,
    precio_venta,
    precio_compra,
    stock,
    id_categoria,
    id_proveedor,
    activo,
    id_rubro
) VALUES (
    '323950508661',
    'nubia Neo 3',
    4500,
    1500,
    10,
    2,  -- id_categoria (de la tabla categorias)
    139,  -- id_proveedor (de la tabla proveedor)
    1,  -- activo (1 = activo)
    2   -- id_rubro (de la tabla rubro)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
